[
  // ============================================================================
  // 이 파일은 settings.json의 "base_keymap": "JetBrains" 위에 얹는 override 집합이다.
  // 각 바인딩은 JetBrains 기본값과 다른 부분만 정의한다.
  // ============================================================================

  // === 터미널 토글 ===
  // F12: 터미널 패널 열기/닫기 (VSCode toggleTerminal 동작 재현)
  // terminal_panel::Toggle = 항상 Terminal 탭을 활성화 + 열기/닫기 토글
  //   (ToggleBottomDock은 마지막 활성 패널을 열어서 Debug 등이 나올 수 있음)
  //   (ToggleFocus는 포커스만 전환하고 패널을 닫지 않음)
  // Terminal 컨텍스트에도 명시 필요 — 안 하면 shell이 F12를 가로챔 (\e[24~ → "~" 출력)
  // ============================================================================
  {
    "bindings": {
      "f12": "terminal_panel::Toggle"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "f12": "terminal_panel::Toggle"
    }
  },

  // ============================================================================
  // 코드 네비게이션
  // Cmd+B → 정의로 이동 (IntelliJ 습관 유지)
  // Zed 기본 Cmd+B = 좌측 독 토글이므로 해제 필요
  // ============================================================================
  {
    "bindings": {
      "cmd-b": null
    }
  },

  // ============================================================================
  // Claude Agent 패널
  // Cmd+\ → Claude Agent 토글 (열기/닫기)
  // CIR: Cmd+\의 기존 바인딩(pane::SplitRight, workspace::ToggleLeftDock,
  //   assistant::InlineAssist)을 모두 덮어씀. 분할은 Cmd+K h/j/k/l 사용.
  // ============================================================================
  {
    "bindings": {
      "cmd-\\": "agent::Toggle"
    }
  },
  {
    "context": "AgentPanel",
    "bindings": {
      "escape": "editor::ToggleFocus"
    }
  },
  {
    "context": "AgentPanel > Markdown",
    "bindings": {
      "escape": "editor::ToggleFocus"
    }
  },
  {
    "context": "AgentPanel || ContextEditor || (MessageEditor > Editor)",
    "bindings": {
      "escape": "editor::ToggleFocus"
    }
  },

  // ============================================================================
  // Git 패널
  // Cmd+9 → Git 패널 토글 (IntelliJ Cmd+9와 동일)
  // CIR: Git Graph(git_graph::Open)는 Zed 0.226.4에서 미활성. nixpkgs 업데이트 후
  //   Alt+Cmd+9로 바인딩 예정.
  // Cmd+K의 기본 git_panel 바인딩을 null 처리하여 Cmd+K chord prefix 복원
  // ============================================================================
  {
    "bindings": {
      "cmd-k": null,
      "cmd-9": "git_panel::Toggle"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-b": "editor::GoToDefinition",
      "f7": "editor::FindAllReferences"
    }
  },

  // ============================================================================
  // 다중 선택
  // Cmd+G → 다음 일치 선택 (VSCode 커스텀: Cmd+D 대신 Cmd+G 사용)
  // Shift+Cmd+G → 모든 일치 선택
  // ============================================================================
  {
    "context": "Editor",
    "bindings": {
      "cmd-g": [
        "editor::SelectNext",
        {
          "replace_newest": false
        }
      ],
      "shift-cmd-g": "editor::SelectAllMatches"
    }
  },

  // ============================================================================
  // 파일 탐색기 + Git 패널 (Vim-style j/k 네비게이션)
  // Cmd+N → 새 파일, Cmd+D → 새 폴더 (explorer 컨텍스트에서만)
  // ============================================================================
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "j": "menu::SelectNext",
      "k": "menu::SelectPrevious",
      "cmd-n": "project_panel::NewFile",
      "cmd-d": "project_panel::NewDirectory"
    }
  },
  {
    "context": "GitPanel && ChangesList",
    "bindings": {
      "j": "menu::SelectNext",
      "k": "menu::SelectPrevious"
    }
  },

  // ============================================================================
  // 찾기/바꾸기
  // Cmd+R Cmd+R → 찾기+바꾸기 (코드 키바인딩, VSCode 패턴 유지)
  // ============================================================================
  {
    "context": "Editor",
    "bindings": {
      "cmd-r cmd-r": [
        "pane::DeploySearch",
        {
          "replace_enabled": true
        }
      ]
    }
  },

  // ============================================================================
  // 파일 경로 복사
  // Shift+Cmd+C → 현재 파일 경로 복사
  // ============================================================================
  {
    "context": "Editor",
    "bindings": {
      "shift-cmd-c": "workspace::CopyPath"
    }
  },

  // ============================================================================
  // 언어 선택 — Zed 기본 Cmd+K M chord 사용 (Cmd+K null 처리로 복원됨)
  // CIR: 이전에 Ctrl+Cmd+M으로 우회했으나, Cmd+K를 git_panel에서 해제(null)하면서
  //   기본 Cmd+K M chord가 복원됨. 커스텀 바인딩 제거.
  // ============================================================================
  // (Cmd+K M = language_selector::Toggle — Zed 기본 바인딩, 커스텀 불필요)

  // ============================================================================
  // 창 분할 + 패인 이동 (Vim h/j/k/l 스타일)
  // Cmd+K h/j/k/l → 분할 (Cmd+K null 처리로 chord 사용 가능)
  // Alt+Cmd+방향키 → 패인 이동 (Ghostty 스타일)
  // CIR: Alt+Cmd+Left/Right는 JetBrains의 탭 전환을 덮어씀 (Cmd+Shift+[/]로 대체 가능).
  //   Alt+Cmd+Down은 JetBrains의 GoToDefinition을 덮어씀 (Cmd+B로 대체 가능).
  // ============================================================================
  {
    "bindings": {
      "cmd-k h": "pane::SplitLeft",
      "cmd-k j": "pane::SplitDown",
      "cmd-k k": "pane::SplitUp",
      "cmd-k l": "pane::SplitRight",
      "alt-cmd-up": "workspace::ActivatePaneUp",
      "alt-cmd-down": "workspace::ActivatePaneDown",
      "alt-cmd-left": "workspace::ActivatePaneLeft",
      "alt-cmd-right": "workspace::ActivatePaneRight"
    }
  },

  // ============================================================================
  // Untitled Buffer (Scratchpad 대체)
  // Shift+Cmd+N → 새 untitled 버퍼 (언어 변경: Ctrl+Cmd+M)
  // CIR: action::Sequence로 NewFile + language_selector::Toggle 시도했으나
  //   비동기 실행으로 동작이 비결정론적이고 언어 선택이 새 버퍼에 미반영. 롤백.
  // JetBrains keymap이 file_finder::Toggle로 바인딩하므로 동일 컨텍스트에서 override
  // ============================================================================
  {
    "context": "Editor && mode == full",
    "bindings": {
      "shift-cmd-n": "workspace::NewFile"
    }
  },
  {
    "bindings": {
      "shift-cmd-n": "workspace::NewFile"
    }
  },

  // ============================================================================
  // 터미널 관리
  // Cmd+T → 새 터미널, Cmd+W → 활성 터미널 닫기
  // ============================================================================
  {
    "context": "Terminal",
    "bindings": {
      "cmd-t": "workspace::NewTerminal",
      "cmd-w": "pane::CloseActiveItem"
    }
  },

  // ============================================================================
  // HTML/JSX 태그 조작 (VSCode Emmet 부분 대체)
  // Alt+Cmd+J → 선택 영역을 태그로 wrap (VSCode: emmet.wrapWithAbbreviation)
  // CIR: Alt+Cmd+K(removeTag)는 미바인딩. Zed의 UnwrapSyntaxNode는 tree-sitter
  //   구문 노드 단위로 동작하여 JSX에서 태그+자식 전체를 제거함 (태그만 벗기지 않음).
  //   VSCode Emmet의 removeTag와 동등한 액션이 Zed에 없음.
  // ============================================================================
  {
    "context": "Editor",
    "bindings": {
      "alt-cmd-j": "editor::WrapSelectionsInTag"
    }
  },

  // ============================================================================
  // Git
  // Alt+Cmd+Z → 파일 변경사항 되돌리기 (VSCode: git.clean)
  // Ctrl+Alt+Cmd+H → 현재 파일의 Git 히스토리 (VSCode: timeline.focus)
  // ============================================================================
  {
    "context": "Editor",
    "bindings": {
      "ctrl-alt-cmd-h": "git::FileHistory"
    }
  },
  {
    "context": "FileHistoryView",
    "bindings": {
      "j": "menu::SelectNext",
      "k": "menu::SelectPrevious"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-cmd-z": "git::RestoreFile"
    }
  },

  // ============================================================================
  // 터미널 줄바꿈
  // Shift+Enter → 백슬래시+개행 입력 (긴 명령어 이어쓰기)
  // ============================================================================
  {
    "context": "Terminal",
    "bindings": {
      "shift-enter": ["terminal::SendText", "\\\n"]
    }
  }
]
