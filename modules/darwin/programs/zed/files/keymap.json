[
  // ============================================================================
  // 이 파일은 settings.json의 "base_keymap": "JetBrains" 위에 얹는 override 집합이다.
  // 각 바인딩은 JetBrains 기본값과 다른 부분만 정의한다.
  // ============================================================================

  // === 터미널 토글 ===
  // F12: 터미널 패널 열기/닫기 (VSCode toggleTerminal 동작 재현)
  // ToggleBottomDock = 패널 표시/숨김 토글 (ToggleFocus는 포커스만 전환하고 닫지 않음)
  // Terminal 컨텍스트에도 명시 필요 — 안 하면 shell이 F12를 가로챔 (\e[24~ → "~" 출력)
  // ============================================================================
  {
    "bindings": {
      "f12": "workspace::ToggleBottomDock"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "f12": "workspace::ToggleBottomDock"
    }
  },

  // ============================================================================
  // 코드 네비게이션
  // Cmd+B → 정의로 이동 (IntelliJ 습관 유지)
  // Zed 기본 Cmd+B = 좌측 독 토글이므로 해제 필요
  // ============================================================================
  {
    "bindings": {
      "cmd-b": null
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-b": "editor::GoToDefinition",
      "f7": "editor::FindAllReferences"
    }
  },

  // ============================================================================
  // 다중 선택
  // Cmd+G → 다음 일치 선택 (VSCode 커스텀: Cmd+D 대신 Cmd+G 사용)
  // Shift+Cmd+G → 모든 일치 선택
  // ============================================================================
  {
    "context": "Editor",
    "bindings": {
      "cmd-g": [
        "editor::SelectNext",
        {
          "replace_newest": false
        }
      ],
      "shift-cmd-g": "editor::SelectAllMatches"
    }
  },

  // ============================================================================
  // 파일 탐색기 (Vim-style j/k 네비게이션)
  // Cmd+N → 새 파일, Cmd+D → 새 폴더 (explorer 컨텍스트에서만)
  // ============================================================================
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "j": "menu::SelectNext",
      "k": "menu::SelectPrevious",
      "cmd-n": "project_panel::NewFile",
      "cmd-d": "project_panel::NewDirectory"
    }
  },

  // ============================================================================
  // 찾기/바꾸기
  // Cmd+R Cmd+R → 찾기+바꾸기 (코드 키바인딩, VSCode 패턴 유지)
  // ============================================================================
  {
    "context": "Editor",
    "bindings": {
      "cmd-r cmd-r": [
        "pane::DeploySearch",
        {
          "replace_enabled": true
        }
      ]
    }
  },

  // ============================================================================
  // 파일 경로 복사
  // Shift+Cmd+C → 현재 파일 경로 복사
  // ============================================================================
  {
    "context": "Editor",
    "bindings": {
      "shift-cmd-c": "workspace::CopyPath"
    }
  },

  // ============================================================================
  // 패널/뷰 크기 조절
  // Ctrl+Alt+]/[ → 에디터 패인 좌우 이동
  // Shift+Alt+]/[ → 활성 독 크기 조절
  // ============================================================================
  {
    "bindings": {
      "ctrl-alt-]": "workspace::SwapPaneRight",
      "ctrl-alt-[": "workspace::SwapPaneLeft",
      "shift-alt-]": "workspace::IncreaseActiveDockSize",
      "shift-alt-[": "workspace::DecreaseActiveDockSize"
    }
  },

  // ============================================================================
  // Untitled Buffer (Scratchpad 대체)
  // Shift+Cmd+N → 새 untitled 버퍼
  // ============================================================================
  {
    "bindings": {
      "shift-cmd-n": "workspace::NewFile"
    }
  },

  // ============================================================================
  // 터미널 관리
  // Cmd+T → 새 터미널, Cmd+W → 활성 터미널 닫기
  // ============================================================================
  {
    "context": "Terminal",
    "bindings": {
      "cmd-t": "workspace::NewTerminal",
      "cmd-w": "pane::CloseActiveItem"
    }
  },

  // ============================================================================
  // Git
  // Alt+Cmd+Z → 파일 변경사항 되돌리기 (VSCode: git.clean)
  // ============================================================================
  {
    "context": "Editor",
    "bindings": {
      "alt-cmd-z": "git::RestoreFile"
    }
  },

  // ============================================================================
  // 터미널 줄바꿈
  // Shift+Enter → 백슬래시+개행 입력 (긴 명령어 이어쓰기)
  // ============================================================================
  {
    "context": "Terminal",
    "bindings": {
      "shift-enter": ["terminal::SendText", "\\\n"]
    }
  }
]
