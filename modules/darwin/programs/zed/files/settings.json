{
  // ============================================================================
  // 기본 설정
  // ============================================================================
  "base_keymap": "JetBrains",

  // ============================================================================
  // 폰트 설정
  // ============================================================================
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_fallbacks": ["D2Coding"], // 한글 폴백
  "buffer_font_features": { "calt": true, "liga": true }, // 리가처 활성화

  // ============================================================================
  // 에디터 동작
  // ============================================================================
  "format_on_save": "on",
  "linked_edits": true, // HTML 태그 동시 편집
  "sticky_scroll": { "enabled": true }, // 스크롤 시 현재 스코프 상단 고정
  "current_line_highlight": "all", // 현재 줄 전체 하이라이트
  "colorize_brackets": true, // 괄호 쌍 색상화
  "minimap": { "show": "auto" }, // 미니맵 호버 시 표시
  "snippet_sort_order": "top", // 스니펫을 자동완성 최상단에 표시
  "autosave": { "after_delay": { "milliseconds": 1000 } },

  // ============================================================================
  // 테마 및 UI
  // ============================================================================
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },
  "icon_theme": "Material Icon Theme",

  // ============================================================================
  // Git
  // ============================================================================
  "git": {
    "inline_blame": {
      "enabled": true,
      "delay_ms": 0,
      "show_commit_summary": true
    },
    "gutter_debounce": 0
  },

  // ============================================================================
  // 터미널
  // ============================================================================
  "terminal": {
    "dock": "bottom",
    "font_family": "JetBrainsMono Nerd Font",
    "working_directory": "current_project_directory"
  },

  // ============================================================================
  // 파일 제외 (claude --worktree 워크트리 포함)
  // ============================================================================
  "file_scan_exclusions": [
    // Zed 기본값 (커스텀 설정 시 override되므로 명시 포함)
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    // 프로젝트 커스텀
    "**/.claude/worktrees",
    "**/node_modules",
    "**/.direnv"
  ],

  // ============================================================================
  // 언어별 설정 (Prettier + ESLint)
  // ============================================================================
  "languages": {
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      },
      "code_actions_on_format": { "source.fixAll.eslint": true },
      "format_on_save": "on"
    },
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      },
      "code_actions_on_format": { "source.fixAll.eslint": true },
      "format_on_save": "on"
    },
    "TSX": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      },
      "code_actions_on_format": { "source.fixAll.eslint": true },
      "format_on_save": "on"
    },
    "JSON": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      },
      "format_on_save": "on"
    },
    "JSONC": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      },
      "format_on_save": "on"
    },
    "Nix": {
      "language_servers": ["nixd", "!nil"],
      "format_on_save": "on"
    }
  },

  // ============================================================================
  // LSP 설정
  // ============================================================================
  "lsp": {
    "nixd": {
      "initialization_options": {
        "formatting": { "command": ["nixfmt"] }
      }
    }
  },

  // ============================================================================
  // 확장 자동 설치 (HM extensions 대신 직접 기입 — CIR #3 참조)
  // ============================================================================
  "auto_install_extensions": {
    "nix": true, // Nix 언어 지원 (tree-sitter + nixd/nil LSP)
    "darcula-dark": true, // Darcula 다크 테마
    "material-icon-theme": true, // Material Design 파일 아이콘
    "terraform": true, // Terraform/HCL 언어 지원
    "comment": true, // TODO/INFO/ERROR 키워드 하이라이트
    "mermaid": true // Mermaid 다이어그램 구문 강조
  },

  // ============================================================================
  // 진단 (Error Lens 대체 — 인라인 에러/경고 표시)
  // ============================================================================
  "diagnostics": {
    "inline": { "enabled": true }
  },

  // ============================================================================
  // 툴바
  // ============================================================================
  "toolbar": { "breadcrumbs": true },

  // ============================================================================
  // 스크롤바
  // ============================================================================
  "scrollbar": { "git_diff": true }
}
