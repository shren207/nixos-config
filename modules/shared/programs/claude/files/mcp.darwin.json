{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect",
        "--channel=stable",
        "--no-usage-statistics"
      ],
      "env": {
        "npm_config_registry": "https://registry.npmjs.org/"
      }
    }
  }
}
