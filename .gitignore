# nix build result
/result

# direnv cache (nix-direnv가 devShell 평가 결과 캐싱)
.direnv/

# 업데이트 스크립트 백업 파일 (중단 시 잔류 가능)
*.bak

# Codex CLI
# 글로벌 gitignore(~/.config/git/ignore)에서 .agents/, AGENTS.md, AGENTS.override.md 등을
# 무시하므로, 이 프로젝트에서 필요한 항목을 negation으로 재허용
!AGENTS.md
!AGENTS.override.md
!.agents/
.codex/

# Codex sync 부산물 (.agents/ 심링크 경유로 .claude/에 생성되는 파일)
.claude/skills/*/agents/
.claude/skills/*/references/references

# run-loop.sh 결과 파일 (evals/queries.json만 tracked)
.claude/skills/*/evals/loop-results-*.json
.claude/skills/*/evals/skill_report_*.html
modules/shared/programs/claude/files/skills/*/evals/loop-results-*.json
modules/shared/programs/claude/files/skills/*/evals/skill_report_*.html

# 브라우저 자동화 인증 상태 파일 (평문 세션 토큰 포함)
auth-state.json
oauth-state.json
2fa-state.json

# playwright-cli 런타임 산출물 (스냅샷, 세션 데이터)
.playwright-cli/

# anchoring-bias baseline measurements (스크립트로 동적 산출, repo에 수치 저장 안 함)
.claude/metrics/

# ScheduleWakeup runtime lock (Claude Code skill 런타임 산출물)
.claude/scheduled_tasks.lock
